{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": false,
  "share": "disabled",
  "model": "${HMOS_OPENCODE_PROVIDER_ID}/${HMOS_OPENCODE_MODEL_ID}",
  "small_model": "${HMOS_OPENCODE_PROVIDER_ID}/${HMOS_OPENCODE_MODEL_ID}",
  "server": {
    "hostname": "${HMOS_OPENCODE_HOST}",
    "port": ${HMOS_OPENCODE_PORT}
  },
  "provider": {
    "${HMOS_OPENCODE_PROVIDER_ID}": {
      "name": "HMOS Score Bailian Coding Plan",
      "npm": "@ai-sdk/anthropic",
      "models": {
        "${HMOS_OPENCODE_MODEL_ID}": {
          "name": "${HMOS_OPENCODE_MODEL_NAME}",
          "limit": {
            "context": 202752,
            "output": 16384
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      },
      "options": {
        "baseURL": "${HMOS_OPENCODE_BASE_URL}",
        "apiKey": "${HMOS_OPENCODE_API_KEY}",
        "timeout": ${HMOS_OPENCODE_TIMEOUT_MS},
        "chunkTimeout": 60000
      }
    }
  },
  "permission": {
    "*": "deny",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.git/**": "deny",
      "**/node_modules/**": "deny",
      "**/oh_modules/**": "deny",
      "**/.hvigor/**": "deny",
      "**/build/**": "deny",
      "**/dist/**": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": "deny",
    "bash": "deny",
    "task": "deny",
    "skill": "deny",
    "lsp": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "question": "deny",
    "external_directory": "deny",
    "doom_loop": "deny"
  }
}
