{
  "name": "hmos-score-agent-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "typecheck": "vue-tsc --noEmit",
    "build:bundle": "vite build",
    "build": "sh -c 'npm run typecheck & typecheck_pid=$!; npm run build:bundle & bundle_pid=$!; wait $typecheck_pid; typecheck_status=$?; wait $bundle_pid; bundle_status=$?; exit $((typecheck_status || bundle_status))'",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "echarts": "^5.6.0",
    "element-plus": "^2.11.8",
    "vue": "^3.5.24",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "vue-tsc": "^2.2.12"
  }
}
