{
  "name": "hmos-score-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev:cli": "tsx src/cli.ts",
    "dev:api": "tsx src/index.ts",
    "launch:score": "node --import tsx src/tools/runInteractiveScore.ts",
    "score": "tsx src/cli.ts",
    "rulepack:export": "node --import tsx src/tools/generateRulePackYaml.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\" \"*.mjs\"",
    "format:fix": "prettier --fix \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\" \"*.mjs\""
  },
  "dependencies": {
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.8",
    "@types/yauzl": "^2.10.3",
    "ajv": "^8.18.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "yauzl": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2"
  }
}
