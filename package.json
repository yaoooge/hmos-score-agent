{
  "name": "hmos-score-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:cli": "tsx src/cli.ts",
    "dev:api": "tsx src/index.ts",
    "launch:score": "node --import tsx src/tools/runInteractiveScore.ts",
    "score": "tsx src/cli.ts",
    "case:patch": "node --import tsx src/tools/generateCasePatch.ts",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.8",
    "ajv": "^8.18.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
