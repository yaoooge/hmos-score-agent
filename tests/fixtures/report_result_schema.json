{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HarmonyOS生成代码评分结果",
  "description": "HarmonyOS NEXT 生成代码评测结果的统一固定 JSON Schema，用于本地落盘与服务端上报。",
  "type": "object",
  "properties": {
    "basic_info": {
      "type": "object",
      "properties": {
        "rubric_version": { "type": "string" },
        "task_type": {
          "type": "string",
          "enum": ["full_generation", "continuation", "bug_fix"]
        },
        "evaluation_mode": {
          "type": "string",
          "enum": ["auto_precheck", "auto_precheck_with_human_review"]
        },
        "rules_enabled": { "type": "boolean" },
        "build_check_enabled": { "type": "boolean" },
        "target_description": { "type": "string" },
        "target_scope": { "type": "string" },
        "task_type_basis": { "type": "string" }
      },
      "required": [
        "rubric_version",
        "task_type",
        "evaluation_mode",
        "rules_enabled",
        "build_check_enabled",
        "target_description",
        "target_scope",
        "task_type_basis"
      ],
      "additionalProperties": false
    },
    "rubric_summary": {
      "type": "object",
      "properties": {
        "task_type": {
          "type": "string",
          "enum": ["full_generation", "continuation", "bug_fix"]
        },
        "evaluation_mode": {
          "type": "string",
          "enum": ["auto_precheck", "auto_precheck_with_human_review"]
        },
        "scenario": { "type": "string" },
        "scoring_method": { "type": "string" },
        "scoring_note": { "type": "string" },
        "common_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "report_emphasis": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dimension_summaries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "weight": { "type": "number" },
              "intent": { "type": "string" },
              "item_summaries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "weight": { "type": "number" },
                    "scoring_bands": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "score": { "type": "number" },
                          "criteria": { "type": "string" }
                        },
                        "required": ["score", "criteria"],
                        "additionalProperties": false
                      }
                    }
                  },
                  "required": ["name", "weight", "scoring_bands"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["name", "weight", "intent", "item_summaries"],
            "additionalProperties": false
          }
        },
        "hard_gates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "score_cap": { "type": "number" }
            },
            "required": ["id", "score_cap"],
            "additionalProperties": false
          }
        },
        "review_rule_summary": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "task_type",
        "evaluation_mode",
        "scenario",
        "scoring_method",
        "scoring_note",
        "common_risks",
        "report_emphasis",
        "dimension_summaries",
        "hard_gates",
        "review_rule_summary"
      ],
      "additionalProperties": false
    },
    "overall_conclusion": {
      "type": "object",
      "properties": {
        "total_score": { "type": "number" },
        "hard_gate_triggered": { "type": "boolean" },
        "summary": { "type": "string" }
      },
      "required": ["total_score", "hard_gate_triggered", "summary"],
      "additionalProperties": false
    },
    "dimension_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "dimension_name": { "type": "string" },
          "dimension_intent": { "type": "string" },
          "score": { "type": "number" },
          "max_score": { "type": "number" },
          "comment": { "type": "string" },
          "item_results": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "item_name": { "type": "string" },
                "item_weight": { "type": "number" },
                "score": { "type": "number" },
                "matched_band": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "score": { "type": "number" },
                        "criteria": { "type": "string" }
                      },
                      "required": ["score", "criteria"],
                      "additionalProperties": false
                    },
                    { "type": "null" }
                  ]
                },
                "confidence": {
                  "type": "string",
                  "enum": ["high", "medium", "low"]
                },
                "review_required": { "type": "boolean" },
                "rationale": { "type": "string" },
                "evidence": { "type": "string" }
              },
              "required": [
                "item_name",
                "item_weight",
                "score",
                "matched_band",
                "confidence",
                "review_required",
                "rationale",
                "evidence"
              ],
              "additionalProperties": false
            }
          }
        },
        "required": [
          "dimension_name",
          "dimension_intent",
          "score",
          "max_score",
          "comment",
          "item_results"
        ],
        "additionalProperties": false
      }
    },
    "rule_violations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule_source": { "type": "string" },
          "rule_id": { "type": "string" },
          "rule_summary": { "type": "string" },
          "affected_items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "handling_result": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "required": [
          "rule_source",
          "rule_id",
          "rule_summary",
          "affected_items",
          "handling_result",
          "evidence"
        ],
        "additionalProperties": false
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "level": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "evidence": { "type": "string" }
        },
        "required": ["level", "title", "description", "evidence"],
        "additionalProperties": false
      }
    },
    "strengths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "main_issues": {
      "type": "array",
      "items": { "type": "string" }
    },
    "human_review_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": { "type": "string" },
          "current_assessment": { "type": "string" },
          "uncertainty_reason": { "type": "string" },
          "suggested_focus": { "type": "string" }
        },
        "required": ["item", "current_assessment", "uncertainty_reason", "suggested_focus"],
        "additionalProperties": false
      }
    },
    "final_recommendation": {
      "type": "array",
      "items": { "type": "string" }
    },
    "current_limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rule_audit_results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule_id": { "type": "string" },
          "rule_source": {
            "type": "string",
            "enum": ["must_rule", "should_rule", "forbidden_pattern"]
          },
          "result": {
            "type": "string",
            "enum": ["满足", "不满足", "不涉及", "待人工复核"]
          },
          "conclusion": { "type": "string" }
        },
        "required": ["rule_id", "rule_source", "result", "conclusion"],
        "additionalProperties": false
      }
    },
    "report_meta": {
      "type": "object",
      "properties": {
        "report_file_name": { "type": "string" },
        "result_json_file_name": { "type": "string" },
        "unit_name": { "type": "string" },
        "generated_at": { "type": "string" }
      },
      "required": ["report_file_name", "result_json_file_name", "unit_name", "generated_at"],
      "additionalProperties": false
    }
  },
  "required": [
    "basic_info",
    "rubric_summary",
    "overall_conclusion",
    "dimension_results",
    "rule_violations",
    "risks",
    "strengths",
    "main_issues",
    "human_review_items",
    "final_recommendation",
    "rule_audit_results",
    "report_meta"
  ],
  "additionalProperties": false
}
